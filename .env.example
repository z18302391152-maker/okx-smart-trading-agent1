# OKX API Configuration
# OKX API configuration file

# OKX API Key (Get from OKX Developer Platform)
OKX_API_KEY=your_api_key_here

# OKX API Secret (Get from OKX Developer Platform)
OKX_API_SECRET=your_api_secret_here

# OKX API Passphrase (Get from OKX Developer Platform)
OKX_API_PASSPHRASE=your_api_passphrase_here

# Optional: Custom API Base URL (Default uses official API)
# OKX_API_BASE_URL=https://www.okx.com

# Optional: Log Level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
